{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend",
            "builder": "@vercel/node",
            "entrypoint": "src/index.ts"
        }
    },
    "rewrites": [
        { "source": "/api/(.*)", "destination": "/_/backend/api/$1" }
    ]
}
